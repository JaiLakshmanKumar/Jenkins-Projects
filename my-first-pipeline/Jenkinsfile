pipeline {
  agent {
    docker { 
      image 'maven:3.9-eclipse-temurin-17-alpine' 
      args '-v /var/run/docker.sock:/var/run/docker.sock'
    }
  }
  stages {
    stage('Build jar file') {
       environment {
        // This tells Maven: "Your home is here, in the workspace I own"
        HOME = "${env.WORKSPACE}"
    }
      
      steps {
        // Use 'mvn', not 'maven'
        echo "Building the application..."
        sh 'ls -ltr'
        sh 'chmod +x ./my-first-pipeline/mvnw '
        sh 'cd my-first-pipeline && ./mvnw clean package' 
      }
    }
    stage('Build Docker Image'){
      steps{
        echo "Building docker image"
        sh 'docker buildx build -t simple-java-app ./my-first-pipeline'
      }
    }
    stage('Run docker file'){
      steps{
        echo "Running docker image"
        sh 'docker run -d -p 8080:8080 --name my-app simple-java-app'
        sh "curl 'http://localhost:8080'" 
      }
    } 
  }
  post{
    always{
      sh 'docker rm -f my-app || true'
    }
  }
  
}